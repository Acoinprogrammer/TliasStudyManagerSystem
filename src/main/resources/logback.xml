<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- 输出到控制台 -->
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <!-- 格式化输出 -->
            <!-- %clr(str){color} -->
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %highlight(%-5level) [%thread] %highlight(%logger{10}):  %msg%n</pattern>
            <charset>utf-8</charset>
        </encoder>
    </appender>
    <!-- 系统文件输出 -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <!-- 日志文件路径 -->
        <file>E:/talis-log/log.log</file>
        <!--  输出地址  -->
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>E:/talis-log/log-%i-%d{yyyy-MM-dd}.log</fileNamePattern>
            <!-- 最多保留历史文件数量 -->
            <MaxHistory>3</MaxHistory>
            <!--     最大文件大小-->
            <maxFileSize>10MB</maxFileSize>
        </rollingPolicy>
<!--         编码器和输出格式 -->
        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{10}:  %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>
    <root level = "info">
        <appender-ref ref="STDOUT"/>
        <appender-ref ref="FILE"/>
    </root>
</configuration>
